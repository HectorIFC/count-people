# Copy to .env and restrict access: cp .env.example .env && chmod 600 .env
# Load before running: set -a && source .env && set +a

# Token from @BotFather. NEVER commit it or paste it in chats/logs.
TELEGRAM_BOT_TOKEN=

# MANDATORY allowlist: comma-separated Telegram user ids (see @userinfobot).
# The bot does not start without it and silently ignores everyone else.
ALLOWED_USER_IDS=

# Optional: "true" replies with the annotated photo (estimated ages)
#SEND_ANNOTATED_PREVIEW=false

# Optional: history CSV path (default ./counts.csv)
#HISTORY_FILE=counts.csv

# Optional: model weights cache dir (default ./models)
#MODELS_DIR=models
